<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Lab_Six"
             x:Class="Lab_Six.MainPage"
             BackgroundColor="Black">

    <ContentPage.BindingContext>
        <local:InventoryViewModel />
    </ContentPage.BindingContext>

    <Grid>
    <HorizontalStackLayout BackgroundColor="Black" Spacing="10" Padding="10">

        <Grid x:Name="GameGrid"
              RowSpacing="0" ColumnSpacing="0" Padding="0"
              HorizontalOptions="Start" VerticalOptions="Start" />

        <VerticalStackLayout Spacing="20" VerticalOptions="Center">

            <Label Text="Inventory" FontSize="24" FontAttributes="Bold"
                   TextColor="White" HorizontalOptions="Center" />

            <CollectionView x:Name="InventoryView"
                            x:DataType="local:InventoryViewModel"
                            ItemsSource="{Binding Items}"
                            SelectionMode="None"
                            WidthRequest="200" HeightRequest="140"
                            BackgroundColor="Black">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="3" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="local:InventoryItem">
                        <Image Source="{Binding ImageUrl}"
                               HeightRequest="60" WidthRequest="60"
                               Aspect="AspectFit" />
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Text="Controls" FontSize="18" FontAttributes="Bold"
                   TextColor="White" HorizontalOptions="Center" />

            <Grid RowSpacing="8" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60" />
                    <ColumnDefinition Width="60" />
                    <ColumnDefinition Width="60" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="60" />
                    <RowDefinition Height="60" />
                    <RowDefinition Height="60" />
                </Grid.RowDefinitions>

                <Button Grid.Column="1" Grid.Row="-1" Text="⇧" FontSize="24"
                        Clicked="Up" BackgroundColor="#444" TextColor="White" />
                <Button Grid.Column="0" Grid.Row="1" Text="◀" FontSize="24"
                        Clicked="Left" BackgroundColor="#444" TextColor="White" />
                <Button Grid.Column="2" Grid.Row="1" Text="▶" FontSize="24"
                        Clicked="Right" BackgroundColor="#444" TextColor="White" />
                <Button Grid.Column="1" Grid.Row="2" Text="⇩" FontSize="24"
                        Clicked="Down" BackgroundColor="#444" TextColor="White" />
            </Grid>

        </VerticalStackLayout>
    </HorizontalStackLayout>

        <Label x:Name="WinLabel"
           Text="YOU WIN"
           FontSize="48"
           FontAttributes="Bold"
           TextColor="Gold"
           HorizontalOptions="Center"
           VerticalOptions="Center"
           IsVisible="False"
           BackgroundColor="#AA000000" />
        
    </Grid>
    
</ContentPage>
