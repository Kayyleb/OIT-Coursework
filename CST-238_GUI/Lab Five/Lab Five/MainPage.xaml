<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Lab_Five.MainPage">

    <ScrollView>
        <Grid>

            <Image Source="grass.jpg" Aspect="AspectFill"
                   HorizontalOptions="Fill" VerticalOptions="Fill" />

            <AbsoluteLayout x:Name="grassLayout">
                <Image x:Name="rock1" Source="rock.png."
                       AbsoluteLayout.LayoutBounds="100,100,200,200"
                       AbsoluteLayout.LayoutFlags="None" ZIndex="100" />

                <Image x:Name="rock2" Source="rock.png."
                       AbsoluteLayout.LayoutBounds="100,100,200,200"
                       AbsoluteLayout.LayoutFlags="None" ZIndex="100" />
            </AbsoluteLayout>
        </Grid>
    </ScrollView>

</ContentPage>
